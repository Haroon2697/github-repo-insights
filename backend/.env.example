PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/github-intelligence?retryWrites=true&w=majority
GITHUB_TOKEN=

# Production: comma-separated frontend origins (Vercel URL, etc.)
# CORS_ORIGIN=https://your-app.vercel.app

# Optional: require this value on all /api requests (header X-Backend-Api-Key or ?apiKey=)
# Do NOT put the same secret in VITE_* — browser bundles expose it. Use only for demos or with a BFF.
# BACKEND_API_KEY=

# Rate limiting for /api (defaults: 15 min window, 200 requests)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200

# Optional Redis (e.g. Upstash) — caches GET /api/analysis/:user/repos and .../summary
# REDIS_URL=redis://default:password@host:6379
# REDIS_CACHE_TTL_SEC=120

# Optional error monitoring
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# AI insights (Phase 6): set at least one key. Order = fallback chain (comma-separated).
# Try in order; skip any provider with an empty key. Put your preferred first.
AI_PROVIDER_ORDER=groq,openrouter,huggingface,openai

# Groq (OpenAI-compatible): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter (OpenAI-compatible): https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=GitHub Intelligence Dashboard

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Hugging Face Inference (optional): https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
HUGGINGFACE_INFERENCE_URL=https://api-inference.huggingface.co/models
