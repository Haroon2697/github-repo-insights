{
  "manifest_version": 3,
  "name": "GitHub Intelligence Dashboard",
  "version": "1.0.0",
  "description": "Jump from GitHub profiles and repos to your deployed Intelligence Dashboard (shareable rankings).",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://github.com/*"],
  "action": {
    "default_title": "Open in Intelligence Dashboard",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
